rule "Penalty: Penalize Weak Filtration"
when
    State(stateType == StateType.WEAK_FILTRATION)
    not Penalty(type == RiskType.WEAK_FILTRATION)
then
    insert(new Penalty(RiskType.WEAK_FILTRATION, -1, 15,
        "MAJOR (Weak Filtration): Filter turnover is below the recommended 3x tank volume per hour.", PenaltySeverity.MAJOR));
    logger.trace("[{}] Penalty Added: Score decreased by 15.", drools.getRule().getName());
end

